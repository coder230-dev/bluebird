{
  "name": "bluebird_pulsewrite",
  "productName": "PulseWrite",
  "version": "1.0.0",
  "description": "An awesome desktop app built with Electron",
  "main": "main.js",
  "author": "230theBest",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder"
  },
  "devDependencies": {
    "electron": "^37.2.5",
    "electron-builder": "^24.13.3",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^10.1.0",
    "electron-window-state": "^5.0.3"
  },
  "build": {
    "appId": "com.bluebird.pulsewrite",
    "productName": "Bluebird PulseWrite",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PulseWrite"
    },
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [],
  "license": "ISC"
}
